# ── BaseballOS backend environment ──────────────────────────────────────────
# Copy this file to `.env` (in the backend/ directory) and adjust the values:
#     cp .env.example .env
# python-dotenv loads this automatically for both `flask` and `python` commands.
# Never commit your real .env — it is gitignored.

# Flask CLI entry point. Lets `flask run` and `flask db ...` discover the app.
FLASK_APP=app.py

# Which config to load: development | production. Defaults to development.
# In development, debug is on and safe local defaults apply. In production the
# app fails fast unless SECRET_KEY and DATABASE_URL are explicitly set (below).
APP_ENV=development

# PostgreSQL connection string. REQUIRED.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# A postgres:// URL (from Render/Heroku/Supabase) is auto-normalized to
# postgresql://, so you can paste it as-is. With APP_ENV=production this MUST
# be set — the app refuses to fall back to the localhost default.
DATABASE_URL=postgresql://postgres:password@localhost:5432/baseballos

# Flask secret key. Any random string is fine for local development. With
# APP_ENV=production the app fails fast if this is unset or left as the dev
# default, so set a strong, unique value before hosting.
SECRET_KEY=change-me-for-local-dev

# MLB Stats API base URL. OPTIONAL — this default is correct for everyone.
MLB_API_BASE=https://statsapi.mlb.com/api/v1

# Enable the in-process daily sync scheduler. OPTIONAL; default off.
# Accepts 1 / true / yes. Leave off for local development and tests.
AUTO_SYNC=false

# Extra allowed CORS origins. OPTIONAL; comma-separated.
# The app already allows http://localhost:5173, http://localhost:3000, and the
# Vercel demo domain. Add your own frontend origin here when hosting.
# Example: CORS_ORIGINS=https://my-frontend.example.com
CORS_ORIGINS=
