# ── BaseballOS backend environment ──────────────────────────────────────────
# Copy this file to `.env` (in the backend/ directory) and adjust the values:
#     cp .env.example .env
# python-dotenv loads this automatically for both `flask` and `python` commands.
# Never commit your real .env — it is gitignored.

# Flask CLI entry point. Lets `flask run` and `flask db ...` discover the app.
FLASK_APP=app.py

# Which config to load: development | test | production. Defaults to development.
# In development, debug is on and DATABASE_URL is required. In production the
# app fails fast unless SECRET_KEY, DATABASE_URL, and ADMIN_API_TOKEN are set.
APP_ENV=development

# PostgreSQL connection string. REQUIRED for local development.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Local development must point at a LOCAL database, such as localhost or
# 127.0.0.1. Do not paste a hosted production database URL into backend/.env.
# A postgres:// URL from a hosted environment is auto-normalized to
# postgresql://, but hosted URLs are accepted only with APP_ENV=production.
DATABASE_URL=postgresql://postgres:password@localhost:5432/baseballos

# Flask secret key. Any random string is fine for local development. With
# APP_ENV=production the app fails fast if this is unset or left as the dev
# default, so set a strong, unique value before hosting.
SECRET_KEY=change-me-for-local-dev

# MLB Stats API base URL. OPTIONAL — this default is correct for everyone.
MLB_API_BASE=https://statsapi.mlb.com/api/v1

# Enable the in-process daily sync scheduler. OPTIONAL; default off.
# Accepts 1 / true / yes. Leave off for local development and tests.
AUTO_SYNC=false

# Extra allowed CORS origins. OPTIONAL; comma-separated.
# The app already allows http://localhost:5173, http://localhost:3000, and the
# Vercel demo domain. Add your own frontend origin here when hosting.
# Example: CORS_ORIGINS=https://my-frontend.example.com
CORS_ORIGINS=

# Admin token guarding operational WRITE endpoints (POST /api/bullpen/sync and
# POST /api/bullpen/fatigue/recalculate). Callers must send it as an
# `X-Admin-Token` header. Leave UNSET locally — those endpoints are then allowed
# in development (with a warning). With APP_ENV=production this MUST be set, or
# the app fails fast at startup. Read-only GET endpoints never require it.
# In hosted production the external daily-sync scheduler sends this value — set
# the same string as the GitHub Actions secret BASEBALLOS_ADMIN_API_TOKEN
# (see docs/SETUP.md → "Automated daily sync").
ADMIN_API_TOKEN=
