# BaseballOS local-only backend environment.
# Copy to backend/.env.local and replace only the local password placeholder.
# Do not commit backend/.env.local.

FLASK_APP=app.py
APP_ENV=development
PYTHON_DOTENV_DISABLED=1
FLASK_SKIP_DOTENV=1
DATABASE_URL=postgresql://baseballos_local:REPLACE_WITH_LOCAL_PASSWORD@localhost:5432/baseballos_local
SECRET_KEY=local-story-review
MLB_API_BASE=https://statsapi.mlb.com/api/v1
AUTO_SYNC=false
CORS_ORIGINS=

# Leave unset for normal local review. With APP_ENV=development and no token,
# protected write endpoints are allowed locally with a warning.
# ADMIN_API_TOKEN=
