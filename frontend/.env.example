# ── BaseballOS frontend environment ─────────────────────────────────────────
# Copy to `.env` only if you need to override the API location:
#     cp .env.example .env
#
# Base ORIGIN of the backend API (no trailing /api — the app appends it).
# Leave this UNSET for local development: the Vite dev server proxies /api to
# http://127.0.0.1:5000 (see vite.config.js), so no value is needed.
# Set it only when the backend is hosted separately (e.g. production builds):
#     VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=

# Note: there is intentionally no frontend admin token. Privileged operational
# endpoints (sync / recalculate) are gated by the backend ADMIN_API_TOKEN and
# must be triggered server-side or with curl (see docs/current/SETUP.md). The
# browser never holds or sends that token, so it can never reach the public
# JS bundle.
