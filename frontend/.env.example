# ── BaseballOS frontend environment ─────────────────────────────────────────
# Copy to `.env` only if you need to override the API location:
#     cp .env.example .env
#
# Base ORIGIN of the backend API (no trailing /api — the app appends it).
# Leave this UNSET for local development: the Vite dev server proxies /api to
# http://127.0.0.1:5000 (see vite.config.js), so no value is needed.
# Set it only when the backend is hosted separately (e.g. production builds):
#     VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=

# Note: there is intentionally no frontend admin token. Privileged operational
# endpoints (sync / recalculate) are gated by the backend ADMIN_API_TOKEN and
# must be triggered server-side or with curl (see docs/current/SETUP.md). The
# browser never holds or sends that token, so it can never reach the public
# JS bundle.

# Home page story source. OFF by default: Home uses its existing story behavior.
# Set to `true` to render Home's stories from the canonical backend feed
# (dashboard.stories). Reversible; a missing/malformed payload falls back to the
# legacy behavior automatically. See docs/design/home_canonical_stories_phase_2.md.
# VITE_USE_CANONICAL_HOME_STORIES=false

# Stories page feed source. OFF by default: Stories uses the legacy Four-Beat
# feed (dashboard.four_beat_stories). Set to `true` to render the Stories page
# from the canonical backend feed (dashboard.stories). Reversible; a
# missing/malformed payload falls back to Four-Beat automatically.
# See docs/design/stories_canonical_feed_phase_3.md.
# VITE_USE_CANONICAL_STORIES_PAGE=false

# Team Board story source. OFF by default: the Team Board shows both the canonical
# StoryCard and the legacy client-generated TeamBullpenStoryPanel. Set to `true`
# to render only the single canonical story (StoryCard) and stop mounting the
# duplicate panel. Reversible; if the canonical story is unavailable, the legacy
# panel returns as a safe fallback. See docs/design/team_board_canonical_migration_phase_4b_4.md.
# VITE_USE_CANONICAL_TEAM_BOARD=false
